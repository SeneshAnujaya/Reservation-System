<%@ page contentType="text/html;charset=UTF-8" %>
<%@ include file="../layout/header.jsp" %>

<div class="dashboard help-page">

    <div class="dashboard-top">
        <div class="dashboard-title">
            <h2>Help &amp; User Guide</h2>
            <p class="subtitle">Everything new staff need to run OceanView HMS</p>
        </div>

        <div class="dashboard-actions">
<%--            <div class="dash-search">--%>
<%--                <i class="fa-solid fa-magnifying-glass"></i>--%>
<%--                <input type="text" placeholder="Search topics..." />--%>
<%--            </div>--%>
        </div>
    </div>

    <div class="help-layout">

        <div class="dash-card help-hero">
            <div class="help-hero-left">
                <div class="help-card-title-wrap">
                    <div class="help-icon"><i class="fa-solid fa-circle-info"></i></div>
                    <h3>Welcome to OceanView HMS</h3>
                </div>
                <p class="dash-muted">
                    Follow these simple guides to create reservations, manage rooms, and complete billing.
                </p>

                <div class="help-tags">
                    <span class="help-tag"><i class="fa-solid fa-user-plus"></i> New staff</span>
                    <span class="help-tag"><i class="fa-solid fa-bed"></i> Front desk</span>
                    <span class="help-tag"><i class="fa-solid fa-file-invoice-dollar"></i> Billing</span>
                </div>
            </div>

<%--            <div class="help-hero-right">--%>
<%--                <ul>--%>
<%--                    <li><b>Need to book a guest?</b> See <span>Creating a Reservation</span></li>--%>
<%--                    <li><b>Guest wants to extend or cancel?</b> See <span>Editing Reservations</span></li>--%>
<%--                    <li><b>Time to checkout?</b> See <span>Checkout &amp; Billing</span></li>--%>
<%--                </ul>--%>
<%--            </div>--%>
        </div>

        <div class="help-grid">

            <div class="dash-card help-card">
                <div class="help-card-title-wrap">
                    <div class="help-icon"><i class="fa-solid fa-calendar-days"></i></div>
                    <h3>Creating a Reservation</h3>
                </div>
                <ol>
                    <li>Open the <b>Reservations</b> page from the sidebar.</li>
                    <li>Click <b>+ Add Reservation</b>.</li>
                    <li>Enter guest name, email and phone number.</li>
                    <li>Select the room type.</li>
                    <li>Choose check-in and check-out dates.</li>
                    <li>Set reservation status to <b>CONFIRMED</b> or <b>PENDING</b>.</li>
                    <li>Click <b>Save Reservation</b>.</li>
                </ol>
            </div>

            <div class="dash-card help-card">
                <div class="help-card-title-wrap">
                    <div class="help-icon"><i class="fa-solid fa-pen-to-square"></i></div>
                    <h3>Editing or Canceling Reservation</h3>
                </div>
                <ol>
                    <li>Go to the <b>Reservations</b> page.</li>
                    <li>Find the reservation in the table.</li>
                    <li>Click the <b>Edit</b> button.</li>
                    <li>Update guest or booking details.</li>
                    <li>Click <b>Save Reservation</b>.</li>
                    <li>To cancel a booking, change status to <b>CANCELLED</b>.</li>
                </ol>
            </div>

            <div class="dash-card help-card">
                <div class="help-card-title-wrap">
                    <div class="help-icon"><i class="fa-solid fa-hotel"></i></div>
                    <h3>Managing Rooms</h3>
                </div>
                <ol>
                    <li>Navigate to the <b>Rooms</b> section.</li>
                    <li>Click <b>Add Room</b>.</li>
                    <li>Enter the room type (e.g. Deluxe, Suite).</li>
                    <li>Enter the room price per night.</li>
                    <li>Click <b>Save Room</b>.</li>
                    <li>Use <b>Edit</b> on the Rooms page to update rates later.</li>
                </ol>
            </div>

            <div class="dash-card help-card">
                <div class="help-card-title-wrap">
                    <div class="help-icon"><i class="fa-solid fa-suitcase-rolling"></i></div>
                    <h3>Guest Check‑in Process</h3>
                </div>
                <ol>
                    <li>Go to the <b>Reservations</b> page.</li>
                    <li>Locate the guest's reservation.</li>
                    <li>Ensure reservation status is <b>CONFIRMED</b>.</li>
                    <li>Verify the check‑in date is today.</li>
                    <li>Assign and prepare the room for the guest.</li>
                </ol>
            </div>

            <div class="dash-card help-card">
                <div class="help-card-title-wrap">
                    <div class="help-icon"><i class="fa-solid fa-credit-card"></i></div>
                    <h3>Checkout &amp; Billing</h3>
                </div>
                <ol>
                    <li>Open the <b>Reservations</b> page.</li>
                    <li>Click the <b>Checkout</b> button on the reservation row.</li>
                    <li>The system calculates total nights automatically.</li>
                    <li>Room rate is loaded from the <b>Rooms</b> table.</li>
                    <li>Total cost is calculated automatically.</li>
                    <li>An invoice is generated and can be viewed/printed in <b>Billings</b>.</li>
                </ol>
            </div>

            <div class="dash-card help-card">
                <div class="help-card-title-wrap">
                    <div class="help-icon"><i class="fa-solid fa-chart-line"></i></div>
                    <h3>Dashboard Overview</h3>
                </div>
                <ul>
                    <li><b>Today's check‑ins</b> – number of arriving guests.</li>
                    <li><b>Today's check‑outs</b> – guests leaving today.</li>
                    <li><b>Total rooms</b> – total capacity configured.</li>
                    <li><b>Total reservations</b> – all active bookings.</li>
                </ul>
                <p class="dash-muted">
                    Use the dashboard every morning and evening to get a quick snapshot of hotel activity.
                </p>
            </div>

        </div>
    </div>
</div>

